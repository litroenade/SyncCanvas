[MASTER]
# 初始化项目路径
init-hook='import sys; sys.path.insert(0, ".")'

[MESSAGES CONTROL]
# 禁用特定警告
disable=
    # Pydantic 模型属性误报
    no-member,
    # 保护成员访问 (框架设计需要)
    protected-access,
    # 重定义内置名称 (如数据库模型的 id)
    redefined-builtin,
    # 行太长 (使用 formatter 处理)
    line-too-long,
    # 缺少 docstring (属性访问器等)
    missing-function-docstring,
    # 导入顺序
    wrong-import-order,
    wrong-import-position,
    # 导入失败 (项目路径问题)
    import-error,

[TYPECHECK]
# 忽略的类 (Pydantic 类型)
ignored-classes=
    FieldInfo,
    BaseModel,
    SQLModel,

# 忽略的模块
ignored-modules=
    pydantic,
    sqlmodel,

[FORMAT]
# 最大行长度
max-line-length=120

[BASIC]
# 允许的变量名
good-names=i,j,k,x,y,id,db,e,el,ws

[DESIGN]
# 最大参数数量
max-args=10
